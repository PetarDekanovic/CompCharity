generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String?
  name          String?
  phone         String?
  address       String?
  city          String?
  county        String?
  eircode       String?
  googleId      String?      @unique
  role          String       @default("USER") // GUEST, USER, ADMIN
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]
  blogPosts     BlogPost[]
}

model Submission {
  id                  String            @id @default(cuid())
  referenceNumber     String            @unique
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])
  fullName            String
  email               String
  phone               String
  address             String?
  city                String?
  location            String            // County in Ireland
  eircode             String?
  type                String            // DONATION, RESALE
  category            String            // Laptop, Desktop, etc.
  brand               String
  model               String
  estimatedAge        String
  condition           String
  description         String
  accessories         String?
  preferredOutcome    String?           // For resale: Charity, Shared, Decided Later
  collectionPreference String           // Collection, Drop-off
  collectionDate      DateTime?         // Scheduled collection date/time
  estimatedPrice      Float?            // For resale 'deadline' buying
  youtubeUrl          String?           // Video demonstration
  status              String            @default("SUBMITTED")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  images              SubmissionImage[]
  notes               SubmissionNote[]
}

model SubmissionImage {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  url          String
  createdAt    DateTime   @default(now())
}

model SubmissionNote {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  content      String
  isAdminOnly  Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String        // Rich text HTML
  excerpt         String?
  featuredImage   String?
  published       Boolean       @default(false)
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  tags            BlogTag[]
  seoTitle        String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  type      String   @default("GENERAL") // GENERAL, PARTNERSHIP, CORPORATE
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model FAQItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  image     String?
  createdAt DateTime @default(now())
}
